{
    "suggest.enablePreview": true,
    "suggest.triggerAfterInsertEnter": true,
    "suggest.maxCompleteItemCount": 10,
    "suggest.noselect": false,
    "diagnostic.checkCurrentLine": true,
    "diagnostic.displayByAle": true,
    "coc.preferences.colorSupport": true,
    "coc.preferences.formatOnSaveFiletypes": [
        "javascript",
        "typescript",
        "typescriptreact",
        "json",
        "javascriptreact",
        "typescript.tsx"
    ],
    "explorer.width": 60,
    "explorer.quitOnOpen": true,
    "explorer.previewAction.onHover": true,
    "explorer.openAction.changeDirectory": false,
    "explorer.icon.enableNerdfont": true,
    "explorer.icon.enableVimDevions": true,
    "explorer.buffer.showHiddenBuffers": true,
    "explorer.file.showHiddenFiles": true,
    "prettier.printWidth": 60,
    "prettier.tabWidth": 4,
    "prettier.singleQuote": true,
    "prettier.trailingComma": "all",
    "prettier.disableLanguages": [],
    "snippets.shortcut": "~",
    "typescript.format.insertSpaceBeforeFunctionParenthesis": true,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyParenthesis": true,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": true,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true
}
